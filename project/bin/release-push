#!/bin/bash

# ****************************************************************
# DEFAULTS

branch="master"
branch_from="develop"
changelog="prepend"

# ****************************************************************
# PREPARE

cd $PROJECT_SRC

# ****************************************************************
# CHECKS

if [[ "$(git rev-parse --abbrev-ref HEAD)" != "$branch" ]]; then
    echo "Работаем только в GIT-ветке \"$branch\"!"
    exit 1
fi

# ****************************************************************
# EXECUTION

version="$(git describe --tags $(git rev-list --tags --max-count=1))"
echo "Пушим тэг \"$version\" в \"$branch\""
git push --atomic origin "$branch" "$version"
echo "Запушили тэг \"$version\" в \"$branch\" 🎉"