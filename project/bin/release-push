#!/bin/bash

# ****************************************************************
# DEFAULTS

branch="master"

# ****************************************************************
# PREPARE

cd $PROJECT_SRC

# ****************************************************************
# CHECKS

if [[ "$(git rev-parse --abbrev-ref HEAD)" != "$branch" ]]; then
    echo "Работаем только в GIT-ветке \"$branch\"!"
    exit 1
fi

# ****************************************************************
# EXECUTION

echo "Пушим ветку \"$branch\""
git push origin "$branch"
echo "Пушим тэги в \"$branch\""
git push --tags origin "$branch"
echo "Запушили ветку \"$branch\" и тэги в неё 🎉"