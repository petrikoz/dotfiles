#!/bin/bash

# ****************************************************************
# DEFAULTS

bump="release"
branch_to="master"
branch_from="develop"
changelog="prepend"

# ****************************************************************
# OPTIONS

while getopts ":p" opt; do
   case $opt in
      p) bump="patch" ;;

      # Option error handling
      ?) shift "$(($#-1))" # читаем все аргументы, начиная с неверного
         args="$@" ;;
   esac
done

# если никаких опций не было послано, то читаем всё
if [ $OPTIND -eq 1 ]; then args="$@"; fi

# ****************************************************************
# PREPARE

cd $PROJECT_SRC


# ****************************************************************
# CHECKS

if [[ "$(git rev-parse --abbrev-ref HEAD)" != "$branch_to" ]]; then
    echo "Работаем только в GIT-ветке \"$branch_to\"!"
    exit 1
fi
if [[ !$(which bump-my-version > /dev/null 2>&1) ]]; then
    echo 'Не установлена утилита "bump-my-version"'
    exit 1
fi
if [[ !$(which git-cliff > /dev/null 2>&1) ]]; then
    echo 'Не установлена утилита "git-cliff"'
    exit 1
fi

# ****************************************************************
# EXECUTION

echo "Сливаем \"$branch_from\""
git merge --no-ff "$branch_from"
echo "Бампим версию"
bump-my-version bump "$bump"
echo "Генерируем ченжлог"
[[ ! -e CHANGELOG.md ]] && changelog="output"
git-cliff --latest --$changelog CHANGELOG.md > /dev/null 2>&1
echo "Обновляем последний коммит: добавили ченжлог"
git commit --all --amend
version="$(git describe --tags $(git rev-list --tags --max-count=1))"
echo "Обновляем последний тэг \"$version\": добавили ченжлог"
git tag --force "$version"
echo "Зарелизили версию \"$version\" 🎉"